# ═══════════════════════════════════════════════════════════
# عيادة الجلدية - متغيرات البيئة
# Dermatology Clinic - Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── قاعدة البيانات (Database) ───────────────────────────
# للنشر على Vercel مع Turso:
# DATABASE_URL="libsql://your-db-name-your-org.turso.io?authToken=your-token"
#
# للتطوير المحلي:
# DATABASE_URL="file:./db/custom.db"
DATABASE_URL="file:./db/custom.db"

# ─── النسخ الاحتياطي التلقائي (Auto Backup Cron) ─────────
# مفتاح سري لحماية endpoint النسخ التلقائي على Vercel
# يجب تعيينه في إعدادات Vercel Environment Variables أيضاً
# CRON_SECRET="your-random-secret-string-here"

# ─── Turso (اختياري للتطوير المحلي) ──────────────────────
# TURSO_DATABASE_URL="file:./db/custom.db"
# TURSO_AUTH_TOKEN=""
